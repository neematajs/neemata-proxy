{
  "name": "@nmtjs/proxy",
  "description": "Rust-based reverse proxy for Neemata, exposed via NAPI.",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "url": "https://github.com/neematajs/neemata-proxy"
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "fmt": "$npm_execpath biome check --diagnostic-level=error --write . && cargo fmt",
    "lint": "$npm_execpath biome lint --diagnostic-level=error . && cargo clippy",
    "check:type": "tsgo -p tsconfig.json --noEmit",
    "build:artifact": "napi build --release",
    "build:js": "napi build --js index.js --platform --output-dir ./dist",
    "build": "$npm_execpath build:debug --release",
    "build:debug": "napi build --js index.js --platform --output-dir ./dist",
    "test": "cargo test && $npm_execpath build:debug && $npm_execpath check:type && vitest run"
  },
  "napi": {
    "binaryName": "neemata-proxy",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "armv7-unknown-linux-gnueabihf"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "3.5.1",
    "@biomejs/biome": "2.3.13",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "vitest": "4.0.18",
    "ws": "^8.18.3"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "optionalDependencies": {
    "@nmtjs/proxy-darwin-x64": "workspace:",
    "@nmtjs/proxy-darwin-arm64": "workspace:",
    "@nmtjs/proxy-linux-x64-gnu": "workspace:",
    "@nmtjs/proxy-linux-x64-musl": "workspace:",
    "@nmtjs/proxy-linux-arm64-gnu": "workspace:",
    "@nmtjs/proxy-linux-arm64-musl": "workspace:",
    "@nmtjs/proxy-linux-arm-gnueabihf": "workspace:"
  }
}
